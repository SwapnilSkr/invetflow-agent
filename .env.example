# LiveKit (same project as invetflow-server)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Must match invetflow-server and your LiveKit agent registration
LIVEKIT_AGENT_NAME=invetflow-agent

# --- Meeting transcription agent (meeting_agent.py) ---
# Must match livekit_meeting_agent_name in invetflow-server config (default: invetflow-meeting-agent)
MEETING_AGENT_NAME=invetflow-meeting-agent

# Invetflow API (no trailing path)
INVETFLOW_API_URL=http://127.0.0.1:3001

# Same value as AGENT_API_SECRET in invetflow-server/.env
AGENT_API_SECRET=replace-with-a-long-random-secret

# OpenAI (STT, LLM, TTS)
OPENAI_API_KEY=

# Provider selection
# STT_PROVIDER=openai          # openai | deepgram
# TTS_PROVIDER=openai          # openai | cartesia

# LLM (OpenAI)
# OPENAI_LLM_MODEL=gpt-4o-mini

# OpenAI STT options (used when STT_PROVIDER=openai)
# OPENAI_STT_MODEL=gpt-4o-transcribe
# OPENAI_STT_REALTIME=true
# OPENAI_STT_LANGUAGE=en
# OPENAI_STT_DETECT_LANGUAGE=false
# OPENAI_STT_NOISE_REDUCTION=near_field
# OPENAI_STT_VAD_THRESHOLD=0.45
# OPENAI_STT_PREFIX_PADDING_MS=500
# OPENAI_STT_SILENCE_DURATION_MS=1000
# OPENAI_STT_PROMPT=

# Deepgram STT options (used when STT_PROVIDER=deepgram for the AI interview agent)
# REQUIRED for meeting_agent.py (human-meeting transcription uses Deepgram nova-3 exclusively)
# DEEPGRAM_API_KEY=
# DEEPGRAM_STT_MODEL=nova-3
# DEEPGRAM_STT_LANGUAGE=en-US
# DEEPGRAM_STT_DETECT_LANGUAGE=false
# DEEPGRAM_STT_INTERIM_RESULTS=true
# DEEPGRAM_STT_SMART_FORMAT=true
# DEEPGRAM_STT_ENDPOINTING_MS=25
# DEEPGRAM_STT_FILLER_WORDS=true

# OpenAI TTS options (used when TTS_PROVIDER=openai)
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=ash

# Cartesia TTS options (used when TTS_PROVIDER=cartesia)
# CARTESIA_API_KEY=
# CARTESIA_TTS_MODEL=sonic-3
# CARTESIA_TTS_VOICE=f786b574-daa5-4673-aa0c-cbe3e8534c02
# CARTESIA_TTS_LANGUAGE=en
# CARTESIA_TTS_SPEED=1.0

# OpenAI's realtime STT applies its own near-field noise reduction; stacking LiveKit NC on
# top degrades transcript quality. Default is off — set to nc / bvc / telephony only if the
# candidate room is genuinely noisy.
# LIVEKIT_AGENT_NOISE_CANCELLATION=off

# Endpointing tuned for interview pauses. Silero is auto-disabled only when
# STT_PROVIDER=openai and OPENAI_STT_REALTIME=true.
# SILERO_MIN_SILENCE_DURATION=0.90
# AGENT_MIN_ENDPOINTING_DELAY=1.0
# AGENT_MAX_ENDPOINTING_DELAY=3.5
